<Window x:Class="ElectricCalculation.Views.UserGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ElectricCalculation.Behaviors"
        mc:Ignorable="d"
        Title="Hướng dẫn sử dụng trực quan"
        Width="1200"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#F7F7F7"
        behaviors:DialogCloser.DialogResult="{Binding DialogResult}">
    <Window.Resources>
        <Style x:Key="GuideTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Margin" Value="0,0,10,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="MaxWidth" Value="280" />
            <Setter Property="Foreground" Value="#FF334155" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFDBEAFE" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FF60A5FA" />
                                <Setter Property="Foreground" Value="#FF1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FF93C5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Hướng dẫn sử dụng trực quan"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF111827" />
                <TextBlock Text="Flow duy nhất từ dữ liệu trống đến xuất hóa đơn 1 khách hàng."
                           Margin="0,6,0,0"
                           Foreground="#FF4B5563"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    ItemsSource="{Binding Sections}"
                    SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource GuideTabItemStyle}" />
            </TabControl.ItemContainerStyle>
                        <TabControl.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding TabTitle}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   LineHeight="18"
                                   MaxHeight="36" />
                        <Border Grid.Row="1"
                                Margin="0,8,0,0"
                                Padding="6,1"
                                HorizontalAlignment="Left"
                                CornerRadius="9"
                                Background="#FFF1F5F9"
                                BorderBrush="#FFE2E8F0"
                                BorderThickness="1">
                            <TextBlock Text="{Binding Steps.Count, StringFormat={} {0} bước}"
                                       FontSize="11"
                                       Foreground="#FF475569" />
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Heading}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#FF111827" />
                                    <TextBlock Text="{Binding Description}"
                                               Margin="0,6,0,0"
                                               Foreground="#FF475569"
                                               TextWrapping="Wrap"
                                               FontSize="13" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="10,6"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Top"
                                        Background="#FFF8FAFC"
                                        BorderBrush="#FFE5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock Text="{Binding Steps.Count, StringFormat={}Flow gồm {0} bước}"
                                               Foreground="#FF334155"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,12,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True">
                            <ItemsControl ItemsSource="{Binding Steps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#FFFFFFFF"
                                                BorderBrush="#FFE5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12"
                                                Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding StepTitle}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FF111827" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,6,0,10"
                                                           Foreground="#FF475569"
                                                           TextWrapping="Wrap"
                                                           FontSize="13" />
                                                <Border BorderBrush="#FFD1D5DB"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Background="#FFF8FAFC">
                                                    <Image Source="{Binding Screenshot}"
                                                           Stretch="Uniform"
                                                           MaxHeight="430" />
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding GeneratedAtText}"
                       Foreground="#FF6B7280"
                       FontSize="12" />
            <Button DockPanel.Dock="Right"
                    Width="120"
                    Height="34"
                    Content="Đóng"
                    IsDefault="True"
                    Command="{Binding CloseCommand}" />
        </DockPanel>
    </Grid>
</Window>

