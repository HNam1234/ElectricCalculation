<Window x:Class="ElectricCalculation.Views.UserGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:ElectricCalculation.Behaviors"
        mc:Ignorable="d"
        Title="Hướng dẫn sử dụng trực quan"
        Width="1200"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F7F7F7"
        behaviors:DialogCloser.DialogResult="{Binding DialogResult}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFFFF"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Hướng dẫn sử dụng trực quan"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FF111827" />
                <TextBlock Text="Mỗi bước bên dưới minh họa theo giao diện ứng dụng."
                           Margin="0,6,0,0"
                           Foreground="#FF4B5563"
                           FontSize="13" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True">
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFFFF"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{Binding StepTitle}"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="#FF111827" />
                                <TextBlock Text="{Binding Description}"
                                           Margin="0,6,0,10"
                                           Foreground="#FF475569"
                                           TextWrapping="Wrap"
                                           FontSize="13" />
                                <Border BorderBrush="#FFD1D5DB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Background="#FFF8FAFC">
                                    <Image Source="{Binding Screenshot}"
                                           Stretch="Uniform"
                                           MaxHeight="430" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding GeneratedAtText}"
                       Foreground="#FF6B7280"
                       FontSize="12" />
            <Button DockPanel.Dock="Right"
                    Width="120"
                    Height="34"
                    Content="Đóng"
                    IsDefault="True"
                    Command="{Binding CloseCommand}" />
        </DockPanel>
    </Grid>
</Window>
