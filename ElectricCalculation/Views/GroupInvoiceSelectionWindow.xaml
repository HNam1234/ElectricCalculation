<Window x:Class="ElectricCalculation.Views.GroupInvoiceSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:ElectricCalculation.Behaviors"
        Title="Chọn hộ cần in"
        Width="1100"
        Height="650"
        MinWidth="900"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        behaviors:DialogCloser.DialogResult="{Binding DialogResult}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding GroupName, StringFormat=Nhóm: {0}}"
                           FontSize="16"
                           FontWeight="Bold" />
                <TextBlock Margin="0,4,0,0">
                    <Run Text="Đã chọn: " />
                    <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="#FFB91C1C"
                           Margin="0,4,0,0" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       VerticalAlignment="Top"
                       Text="{Binding TotalCount, Mode=OneWay, StringFormat=Tổng hộ: {0}}"
                       Margin="10,2,0,0" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionUnit="FullRow"
                      SelectionMode="Extended"
                      behaviors:DataGridRightClickSelectBehavior.IsEnabled="True"
                      behaviors:DataGridDragSelectBehavior.IsEnabled="True"
                      behaviors:DataGridSelectRowOnClickBehavior.IsEnabled="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Chọn in (các dòng bôi đen)"
                                  Command="{Binding SelectHighlightedCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Bỏ in (các dòng bôi đen)"
                                  Command="{Binding ClearHighlightedCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <MenuItem Header="Đảo chọn (các dòng bôi đen)"
                                  Command="{Binding ToggleHighlightedCommand}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="In"
                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Width="55" />
                    <DataGridTextColumn Header="STT" Binding="{Binding SequenceNumber, Mode=OneWay}" IsReadOnly="True" Width="55" />
                    <DataGridTextColumn Header="Tên khách" Binding="{Binding Name, Mode=OneWay}" IsReadOnly="True" Width="2*" />
                    <DataGridTextColumn Header="Công tơ" Binding="{Binding MeterNumber, Mode=OneWay}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="Vị trí" Binding="{Binding Location, Mode=OneWay}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address, Mode=OneWay}" IsReadOnly="True" Width="2*" />
                    <DataGridTextColumn Header="SĐT hộ" Binding="{Binding HouseholdPhone, Mode=OneWay}" IsReadOnly="True" Width="*" />
                    <DataGridTextColumn Header="SĐT" Binding="{Binding Phone, Mode=OneWay}" IsReadOnly="True" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#FFE5E7EB" />

            <ScrollViewer Grid.Column="2"
                          Margin="10,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <GroupBox Header="Tuỳ biến" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.Resources>
                                <Style x:Key="ManualTextBoxStyle" TargetType="{x:Type TextBox}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseAutoHeaderFields}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Resources>

                            <CheckBox Grid.ColumnSpan="2"
                                      Content="Tự động lấy thông tin (Kính gửi/Địa chỉ/Đại diện/Điện thoại)"
                                      IsChecked="{Binding UseAutoHeaderFields, Mode=TwoWay}"
                                      Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Text="Kỳ:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1"
                                     Grid.Row="1"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding PeriodLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Text="Người lập:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox Grid.Row="2"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding IssuerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3" Text="Địa điểm:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding IssuePlace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="4" Text="Ngày:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <DatePicker Grid.Row="4"
                                        Grid.Column="1"
                                        Margin="0,6,0,0"
                                        SelectedDate="{Binding IssueDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="5" Text="Kính gửi:" VerticalAlignment="Center" Margin="0,10,0,0" />
                            <TextBox Grid.Row="5"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,10,0,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource ManualTextBoxStyle}"
                                     Text="{Binding RecipientName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="6" Text="Địa chỉ:" VerticalAlignment="Top" Margin="0,6,0,0" />
                            <TextBox Grid.Row="6"
                                     Grid.Column="1"
                                     MinHeight="52"
                                     Margin="0,6,0,0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource ManualTextBoxStyle}"
                                     Text="{Binding ConsumptionAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="7" Text="Đại diện:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox Grid.Row="7"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource ManualTextBoxStyle}"
                                     Text="{Binding RepresentativeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="8" Text="ĐT hộ:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox Grid.Row="8"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource ManualTextBoxStyle}"
                                     Text="{Binding HouseholdPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="9" Text="ĐT đại diện:" VerticalAlignment="Center" Margin="0,6,0,0" />
                            <TextBox Grid.Row="9"
                                     Grid.Column="1"
                                     Height="28"
                                     Margin="0,6,0,0"
                                     VerticalContentAlignment="Center"
                                     Style="{StaticResource ManualTextBoxStyle}"
                                     Text="{Binding RepresentativePhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Xem trước">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding PreviewHeaderText}"
                                       TextWrapping="Wrap" />

                            <Separator Grid.Row="1" Margin="0,8,0,8" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding PreviewRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      RowHeaderWidth="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="STT" Binding="{Binding Stt, Mode=OneWay}" Width="50" />
                                    <DataGridTextColumn Header="CS mới" Binding="{Binding CurrentIndex, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="CS cũ" Binding="{Binding PreviousIndex, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="HS" Binding="{Binding Multiplier, Mode=OneWay}" Width="55" />
                                    <DataGridTextColumn Header="kWh" Binding="{Binding Consumption, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="Trợ giá" Binding="{Binding SubsidizedKwh, Mode=OneWay}" Width="70" />
                                    <DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, Mode=OneWay}" Width="80" />
                                    <DataGridTextColumn Header="Thành tiền" Binding="{Binding Amount, Mode=OneWay}" Width="90" />
                                    <DataGridTextColumn Header="Tên" Binding="{Binding Name, Mode=OneWay}" Width="140" />
                                    <DataGridTextColumn Header="Địa chỉ" Binding="{Binding Address, Mode=OneWay}" Width="200" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="3"
                                       Margin="0,8,0,0"
                                       Text="{Binding PreviewFooterText}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <DockPanel Grid.Row="2"
                   Margin="0,10,0,0"
                   LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="Chọn hết"
                        Width="90"
                        Margin="0,0,8,0"
                        Command="{Binding SelectAllCommand}" />
                <Button Content="Bỏ chọn"
                        Width="90"
                        Command="{Binding ClearAllCommand}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="OK"
                        Width="90"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Command="{Binding OkCommand}" />
                <Button Content="Hủy"
                        Width="90"
                        IsCancel="True"
                        Command="{Binding CancelCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
